    AssertFmtEq("'%-7.7u'",         1234567,        "'1234567'");
    AssertFmtEq("'%-7.9u'",         1234567,        "'1234567'");
    AssertFmtEq("'%-7.20u'",        1234567,        "'1234567'");
    AssertFmtEq("'%-9.u'",          1234567,        "'1234567  '");
