    AssertFmtStrEq("'%032.32s'",        "Some String Text",     "'                Some String Text'");

    AssertFmtStrEq("'%-0.s'",           "Some String Text",     "''");
    AssertFmtStrEq("'%-0.0s'",          "Some String Text",     "''");
    AssertFmtStrEq("'%-0.10s'",         "Some String Text",     "'Some Strin'");
