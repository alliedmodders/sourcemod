void TestUInt()
{
    SetTestContext("Test Unsigned Integer");

    // Base
    AssertFmtEq("'%u'",             0,              "'0'");
    AssertFmtEq("'%u'",             128,            "'128'");
    AssertFmtEq("'%u'",             1234567,        "'1234567'");
    AssertFmtEq("'%u'",             2147483647,     "'2147483647'");
    AssertFmtEq("'%u'",             4294967295,     "'4294967295'");
    AssertFmtEq("'%u'",             -1,             "'4294967295'");

    // Precision
    AssertFmtEq("'%.0u'",           1234567,        "'1234567'");
    AssertFmtEq("'%.3u'",           1234567,        "'1234567'");
    AssertFmtEq("'%.7u'",           1234567,        "'1234567'");
    AssertFmtEq("'%.9u'",           1234567,        "'1234567'");
    AssertFmtEq("'%.20u'",          1234567,        "'1234567'");

    // Width
    AssertFmtEq("'%0u'",            1234567,        "'1234567'");
    AssertFmtEq("'%3u'",            1234567,        "'1234567'");
    AssertFmtEq("'%7u'",            1234567,        "'1234567'");
    AssertFmtEq("'%9u'",            1234567,        "'  1234567'");
    AssertFmtEq("'%20u'",           1234567,        "'             1234567'");

    // Width & Precision
    AssertFmtEq("'%0.3u'",          1234567,        "'1234567'");
    AssertFmtEq("'%0.7u'",          1234567,        "'1234567'");
    AssertFmtEq("'%0.9u'",          1234567,        "'1234567'");
    AssertFmtEq("'%3.3u'",          1234567,        "'1234567'");
    AssertFmtEq("'%3.7u'",          1234567,        "'1234567'");
    AssertFmtEq("'%3.9u'",          1234567,        "'1234567'");
    AssertFmtEq("'%7.3u'",          1234567,        "'1234567'");
    AssertFmtEq("'%7.7u'",          1234567,        "'1234567'");
    AssertFmtEq("'%7.9u'",          1234567,        "'1234567'");
    AssertFmtEq("'%9.3u'",          1234567,        "'  1234567'");
    AssertFmtEq("'%9.7u'",          1234567,        "'  1234567'");
    AssertFmtEq("'%9.9u'",          1234567,        "'  1234567'");
    AssertFmtEq("'%20.3u'",         1234567,        "'             1234567'");
    AssertFmtEq("'%20.7u'",         1234567,        "'             1234567'");
    AssertFmtEq("'%20.9u'",         1234567,        "'             1234567'");

    // Flags
    AssertFmtEq("'%0u'",            1234567,        "'1234567'");
    AssertFmtEq("'%-u'",            1234567,        "'1234567'");
    AssertFmtEq("'%0-u'",           1234567,        "'1234567'");

    // Flags & Precision
    AssertFmtEq("'%0.u'",           1234567,        "'1234567'");
    AssertFmtEq("'%0.0u'",          1234567,        "'1234567'");
    AssertFmtEq("'%0.3u'",          1234567,        "'1234567'");
    AssertFmtEq("'%0.7u'",          1234567,        "'1234567'");
    AssertFmtEq("'%0.9u'",          1234567,        "'1234567'");
    AssertFmtEq("'%0.20u'",         1234567,        "'1234567'");
    AssertFmtEq("'%-.u'",           1234567,        "'1234567'");
    AssertFmtEq("'%-.0u'",          1234567,        "'1234567'");
    AssertFmtEq("'%-.3u'",          1234567,        "'1234567'");
    AssertFmtEq("'%-.7u'",          1234567,        "'1234567'");
    AssertFmtEq("'%-.9u'",          1234567,        "'1234567'");
    AssertFmtEq("'%-.20u'",         1234567,        "'1234567'");
    AssertFmtEq("'%-0.u'",          1234567,        "'1234567'");
    AssertFmtEq("'%-0.0u'",         1234567,        "'1234567'");
    AssertFmtEq("'%-0.3u'",         1234567,        "'1234567'");
    AssertFmtEq("'%-0.7u'",         1234567,        "'1234567'");
    AssertFmtEq("'%-0.9u'",         1234567,        "'1234567'");
    AssertFmtEq("'%-0.20u'",        1234567,        "'1234567'");

    // Flags & Width
    AssertFmtEq("'%00u'",           1234567,        "'1234567'");
    AssertFmtEq("'%03u'",           1234567,        "'1234567'");
    AssertFmtEq("'%07u'",           1234567,        "'1234567'");
    AssertFmtEq("'%09u'",           1234567,        "'001234567'");
    AssertFmtEq("'%020u'",          1234567,        "'00000000000001234567'");
    AssertFmtEq("'%-0u'",           1234567,        "'1234567'");
    AssertFmtEq("'%-3u'",           1234567,        "'1234567'");
    AssertFmtEq("'%-7u'",           1234567,        "'1234567'");
    AssertFmtEq("'%-9u'",           1234567,        "'1234567  '");
    AssertFmtEq("'%-20u'",          1234567,        "'1234567             '");
    AssertFmtEq("'%-00u'",          1234567,        "'1234567'");
    AssertFmtEq("'%-03u'",          1234567,        "'1234567'");
    AssertFmtEq("'%-07u'",          1234567,        "'1234567'");
    AssertFmtEq("'%-09u'",          1234567,        "'123456700'");
    AssertFmtEq("'%-020u'",         1234567,        "'12345670000000000000'");

    // Flags & Precision & Width
    AssertFmtEq("'%00.u'",          1234567,        "'1234567'");
    AssertFmtEq("'%00.0u'",         1234567,        "'1234567'");
    AssertFmtEq("'%00.3u'",         1234567,        "'1234567'");
    AssertFmtEq("'%00.7u'",         1234567,        "'1234567'");
    AssertFmtEq("'%00.9u'",         1234567,        "'1234567'");
    AssertFmtEq("'%00.20u'",        1234567,        "'1234567'");
    AssertFmtEq("'%03.u'",          1234567,        "'1234567'");
    AssertFmtEq("'%03.0u'",         1234567,        "'1234567'");
    AssertFmtEq("'%03.3u'",         1234567,        "'1234567'");
    AssertFmtEq("'%03.7u'",         1234567,        "'1234567'");
    AssertFmtEq("'%03.9u'",         1234567,        "'1234567'");
    AssertFmtEq("'%03.20u'",        1234567,        "'1234567'");
    AssertFmtEq("'%07.u'",          1234567,        "'1234567'");
    AssertFmtEq("'%07.0u'",         1234567,        "'1234567'");
    AssertFmtEq("'%07.3u'",         1234567,        "'1234567'");
    AssertFmtEq("'%07.7u'",         1234567,        "'1234567'");
    AssertFmtEq("'%07.9u'",         1234567,        "'1234567'");
    AssertFmtEq("'%07.20u'",        1234567,        "'1234567'");
    AssertFmtEq("'%09.u'",          1234567,        "'001234567'");
    AssertFmtEq("'%09.0u'",         1234567,        "'001234567'");
    AssertFmtEq("'%09.3u'",         1234567,        "'001234567'");
    AssertFmtEq("'%09.7u'",         1234567,        "'001234567'");
    AssertFmtEq("'%09.9u'",         1234567,        "'001234567'");
    AssertFmtEq("'%09.20u'",        1234567,        "'001234567'");
    AssertFmtEq("'%020.u'",         1234567,        "'00000000000001234567'");
    AssertFmtEq("'%020.0u'",        1234567,        "'00000000000001234567'");
    AssertFmtEq("'%020.3u'",        1234567,        "'00000000000001234567'");
    AssertFmtEq("'%020.7u'",        1234567,        "'00000000000001234567'");
    AssertFmtEq("'%020.9u'",        1234567,        "'00000000000001234567'");
    AssertFmtEq("'%020.20u'",       1234567,        "'00000000000001234567'");

    AssertFmtEq("'%-0.u'",          1234567,        "'1234567'");
    AssertFmtEq("'%-0.0u'",         1234567,        "'1234567'");
    AssertFmtEq("'%-0.3u'",         1234567,        "'1234567'");
