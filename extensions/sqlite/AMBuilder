import os
import sys
import subprocess

for cxx in builder.targets:
  binary = SM.ExtLibrary(builder, cxx, 'dbi.sqlite.ext')
  binary.compiler.cxxincludes += [
    os.path.join(SM.mms_root, 'core', 'sourcehook'),
  ]
  if binary.compiler.family == 'gcc' or binary.compiler.family == 'clang':
    binary.compiler.cxxflags += ['-fno-rtti']
  elif binary.compiler.family == 'msvc':
    binary.compiler.cxxflags += ['/GR-']

  binary.compiler.defines += [
    'SQLITE_OMIT_LOAD_EXTENSION',
    'SQLITE_THREADSAFE',
    'SQLITE_USE_URI',
    'SQLITE_ALLOW_URI_AUTHORITY',
    'SQLITE_ENABLE_MATH_FUNCTIONS',
  ]
  if binary.compiler.target.platform == 'linux':
    binary.compiler.postlink += ['-ldl', '-lpthread']

  sqlite_dir = os.path.join(os.path.dirname(__file__), 'sqlite-source')
  if not os.path.exists(os.path.join(sqlite_dir, 'sqlite3.c')):
    original_cwd = os.getcwd()
    try:
      os.chdir(sqlite_dir)
      if os.name == 'nt':
        subprocess.run(['nmake', '/f', 'Makefile.msc', 'clean'], check=False, capture_output=True)
        subprocess.run(['nmake', '/f', 'Makefile.msc', 'sqlite3.c'], check=True, capture_output=True)
      else:
        subprocess.run(['make', 'distclean'], check=False, capture_output=True)
        subprocess.run(['./configure'], check=True, capture_output=True)
        subprocess.run(['make', 'sqlite3.c'], check=True, capture_output=True)
    except subprocess.CalledProcessError as e:
      if e.stderr:
        print(e.stderr.decode(errors='replace'), file=sys.stderr)
      raise
    finally:
      os.chdir(original_cwd)

  binary.sources += [
    '../../public/smsdk_ext.cpp',
    'extension.cpp',
    'driver/SqDatabase.cpp',
    'driver/SqDriver.cpp',
    'driver/SqQuery.cpp',
    'driver/SqResults.cpp',
    'sqlite-source/sqlite3.c'
  ]

  SM.extensions += [builder.Add(binary)]